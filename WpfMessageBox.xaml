<Window
    x:Class="TempFileCleaner.WpfMessageBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TempFileCleaner"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Message"
    Width="490"
    Height="250"
    AllowsTransparency="True"
    Background="Transparent"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">
    <Window.Resources>
        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#383838" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Aptos Mono" />
            <Setter Property="Padding" Value="15,8" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3498db" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2980b9" />
                                <!--<Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
                                    </Setter.Value>
                                </Setter>-->
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border
        Margin="6"
        Background="#151515"
        BorderBrush="DodgerBlue"
        BorderThickness="1"
        CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="10"
                Opacity="0.4"
                ShadowDepth="4"
                Color="#000000" />
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Image
                x:Name="imgOk"
                Grid.Row="0"
                Width="36"
                Height="36"
                Margin="-10"
                HorizontalAlignment="Left"
                Opacity="0.9"
                RenderOptions.BitmapScalingMode="Fant"
                Source="/Logo_Normal.png"
                Visibility="Visible" />
            <Image
                x:Name="imgErr"
                Grid.Row="0"
                Width="36"
                Height="36"
                Margin="-10"
                HorizontalAlignment="Left"
                Opacity="0.9"
                RenderOptions.BitmapScalingMode="Fant"
                Source="/Logo_Warn.png"
                Visibility="Collapsed" />
            <TextBlock
                x:Name="MessageText"
                Grid.Row="1"
                Margin="8,0,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="16"
                Foreground="White"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                Text="Message Here"
                TextWrapping="Wrap" />
            <StackPanel
                Grid.Row="2"
                Margin="0,10,0,-1"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    x:Name="btnOK"
                    Width="90"
                    Height="34"
                    Click="Ok_Click"
                    Content="OK"
                    IsDefault="True" />
                <Button
                    x:Name="btnCancel"
                    Width="90"
                    Height="34"
                    Margin="6,0,0,0"
                    Click="Cancel_Click"
                    Content="Cancel"
                    IsDefault="False" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
